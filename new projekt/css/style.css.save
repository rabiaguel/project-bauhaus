body {
    font-family: Arial, sans-serif;
    margin: 0;
    background-color: #f4f4f4;
    padding-bottom: 80px;
}

.top-nav {
    display: flex;
    justify-content: flex-end;
    padding: 15px 40px;
    background-color: #000;
}

.about-btn {
    color: #fff;
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: bold;
    border: 2px solid #fff;
    padding: 6px 16px;
    border-radius: 4px;
    transition: background 0.3s, color 0.3s;
}

.about-btn:hover {
    background-color: #fff;
    color: #000;
}

.main-header {
    background: #000;
    color: #fff;
    padding: 40px 20px;
    text-align: center;
    margin-bottom: 40px;
}

.main-header h1 {
    letter-spacing: 12px;
    margin: 0;
    font-size: 2.5rem;
}

.content-wrapper {
    padding: 0 40px;
    max-width: 1200px;
    margin: 0 auto;
}

.intro-text {
    margin-bottom: 50px;
    line-height: 1.8;
    color: #111;
    font-size: 1.2rem;
    max-width: 900px;
}

.section-title {
    font-size: 1.8rem;
    border-bottom: 3px solid #000;
    padding-bottom: 15px;
    margin-top: 80px;
    margin-bottom: 40px;
    letter-spacing: 2px;
    position: relative;
    z-index: 1;
}

.section-title::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 120px;
    height: 120px;
    z-index: -1;
    opacity: 0.18;
}

.title-phases::before {
    background-color: #ff3333;
    border-radius: 50%;
}

.title-meister::before {
    background-color: #3333ff;
    width: 100px;
    height: 100px;
}

.title-werke::before {
    width: 0;
    height: 0;
    background-color: transparent;
    border-left: 60px solid transparent;
    border-right: 60px solid transparent;
    border-bottom: 105px solid #f39c12;
}

.grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
    margin-bottom: 60px;
    align-items: stretch;
}

.card {
    background: #fff;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    height: 100%;
}

.phase-weimar { border-top: 15px solid #ff3333; }
.phase-dessau { border-top: 15px solid #3333ff; }
.phase-berlin { border-top: 15px solid #f39c12; }

.image-container {
    width: 100%;
    height: 220px;
    overflow: hidden;
    background: #eee;
}

.image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.card-content {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
}

.card-content h3 {
    margin: 0 0 10px 0;
    font-size: 1.3rem;
    color: #000;
}

.card-content p {
    line-height: 1.6;
    color: #333;
    margin: 0;
    font-size: 0.95rem;
}

.master-card {
    background: #000;
    color: #fff;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    height: 100%;
}

.master-image-container {
    width: 100%;
    height: 300px;
    overflow: hidden;
    background: #222;
}

.master-image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    display: block;
}

.master-content {
    padding: 25px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
}

.master-role {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #aaa;
    display: block;
    margin-bottom: 5px;
}

.master-content h3 {
    margin: 5px 0 12px 0;
    font-size: 1.5rem;
    color: #fff;
}

.master-content p {
    line-height: 1.6;
    color: #ddd;
    margin: 0;
    font-size: 0.9rem;
}

.main-footer {
    background-color: #000;
    color: #fff;
    text-align: center;
    padding: 20px;
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    box-sizing: border-box;
}

.footer-link {
    color: #aaa;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s;
}

.footer-link:hover {
    color: #fff;
}

.impressum-container {
    max-width: 800px;
    margin: 40px auto;
    background: #fff;
    padding: 40px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    line-height: 1.8;
}

.impressum-container h1 {
    border-bottom: 3px solid #000;
    padding-bottom: 10px;
    margin-bottom: 20px;
}

.about-link {
    color: #3333ff;
    text-decoration: underline;
}

.about-link:hover {
    color: #000;
}
